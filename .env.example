# Copy to .env (or .env.local) and fill in. NEVER commit your real .env.

# ---- Supabase (required for the dashboard) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase service role (only for the sync pipeline; server-only, never exposed) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Google service account (Sheets API, read-only) — for the sync pipeline ----
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Spreadsheet ID (the long id between /d/ and /edit in the sheet URL) ----
SHEET_LEANR_ID=1DNhc8CISBRAVVWZXGb-hMHGB9fruVSsJvZB_3KraNuw

# ---- Upstash QStash (scheduled sync) ----
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
